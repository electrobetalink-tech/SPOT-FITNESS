{
  "name": "spot-fitness",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "npm run lint && npm run typecheck",
    "ci:check": "npm run lint && npm run typecheck && npm run build",
    "vercel:pull": "npx vercel pull --yes --environment=production --token=$VERCEL_TOKEN",
    "vercel:build": "npx vercel build --prod --token=$VERCEL_TOKEN",
    "vercel:deploy": "npx vercel deploy --prebuilt --prod --token=$VERCEL_TOKEN"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.49.8",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.511.0",
    "next": "14.2.5",
    "qrcode": "^1.5.4",
    "react": "^18",
    "react-dom": "^18",
    "zod": "^3.24.2",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}
